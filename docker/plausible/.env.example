# Plausible Analytics — Environment-Konfiguration
# Auf dem Server unter docker/plausible/.env ablegen.

# Postgres-Passwort. Beliebige starke Zeichenfolge.
POSTGRES_PASSWORD=CHANGE_ME

# SECRET_KEY_BASE (mindestens 64 Bytes, Base64). Generieren:
#   openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=CHANGE_ME

# TOTP_VAULT_KEY (32 Bytes, Base64). Generieren:
#   openssl rand -base64 32 | tr -d '\n'
TOTP_VAULT_KEY=CHANGE_ME

# Beim ersten Hochfahren auf false lassen, dann ersten Admin-Account anlegen.
# Danach auf invite_only setzen und Container neu starten.
DISABLE_REGISTRATION=false

# Mail-Absender. Aktuell ohne SMTP-Konfig, Mails landen im Container-Log.
# Wenn Mail-Versand gebraucht wird (Invite-Links, Reports), SMTP_*-Vars
# nach Plausible-Doku ergaenzen.
MAILER_EMAIL=noreply@blackout24.de
