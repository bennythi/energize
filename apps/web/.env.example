# Sanity Cloud (public — darf ins Bundle)
PUBLIC_SANITY_PROJECT_ID=oxliq7rf
PUBLIC_SANITY_DATASET=production

# Supabase (public — darf ins Bundle, RLS schützt die Daten)
PUBLIC_SUPABASE_URL=https://__project_id__.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<anon-public-key-aus-supabase-dashboard>

# Sentry Error-Monitoring (public — DSN ist absichtlich oeffentlich,
# schuetzt sich serverseitig per Project-Rate-Limits).
# Free-Tier-Account auf https://sentry.io anlegen, neues SvelteKit-Projekt,
# DSN aus Settings → Client Keys (DSN) kopieren. Bei leerem Wert ist
# Sentry deaktiviert. Aktiv nur auf der Produktionsdomain (siehe
# apps/web/src/hooks.client.ts).
PUBLIC_SENTRY_DSN=
