# Energize Festival 2027 — Apache config for adapter-static SvelteKit build
# Liegt unter apps/web/static/.htaccess und landet im build-Root.

Options +MultiViews
DirectoryIndex index.html

# Charset für alle textartigen Antworten
AddDefaultCharset UTF-8

# Lange Caches für gehashte Assets, kurz für HTML
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|svg|png|jpg|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Brotli/Gzip-Kompression einschalten falls verfügbar
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# SPA-Fallback: alle Requests, die kein existierendes File/Directory treffen,
# bekommen index.html — der SvelteKit-Client übernimmt das Routing
# (z. B. /lineup/brennan-heart → SvelteKit-Router löst Dynamic-Route auf).
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Echte Files/Dirs durchlassen
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Sonst Fallback auf index.html
  RewriteRule ^ /index.html [L]
</IfModule>

# Sicherheitsheader
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # Clickjacking-Schutz: niemand darf uns iframen
  Header always set X-Frame-Options "DENY"

  # HSTS: ein Jahr, alle Subdomains
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # CSP: erlaubte Quellen sind self + Supabase (Projekt-Host) + Sanity-CDN
  # + Google Fonts. Inline-Styles wegen Tailwind, Inline-Scripts wegen
  # SvelteKit-Hydration-Bootstrap (adapter-static kann keine Nonces setzen).
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: blob: https://zmazyriysvintuwlyzfm.supabase.co https://cdn.sanity.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline' https://plausible.blackout24.de; connect-src 'self' https://zmazyriysvintuwlyzfm.supabase.co https://oxliq7rf.api.sanity.io https://oxliq7rf.apicdn.sanity.io wss://zmazyriysvintuwlyzfm.supabase.co https://plausible.blackout24.de https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://*.ingest.de.sentry.io; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; frame-src https://shop.tickee.de"
</IfModule>
