{
  "name": "@energize/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./messages": "./src/paraglide/messages.js",
    "./runtime": "./src/paraglide/runtime.js"
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "dev": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --watch",
    "postinstall": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide || echo 'paraglide compile skipped'",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^1.11.8"
  },
  "devDependencies": {
    "@energize/tsconfig": "workspace:*",
    "typescript": "^5.7.2"
  }
}
